ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Embeddings backend ---
# "voyage": Voyage AI API (voyage-3-lite). Slim image, requires VOYAGE_API_KEY.
# "local":  sentence-transformers (all-MiniLM-L6-v2). Free but pulls in PyTorch
#           — only available if installed with `uv sync --extra local`.
EMBEDDING_BACKEND=voyage

# --- Reranker backend ---
# Enables two-stage retrieval: bi-encoder (top-20) → cross-encoder rerank (top-5).
# "off":    skip reranking, return top-3 directly from the embedder.
# "voyage": Voyage rerank-2.5 API.
# "local":  BAAI/bge-reranker-base (requires --extra local).
RERANKER_BACKEND=voyage

# Required if EMBEDDING_BACKEND=voyage or RERANKER_BACKEND=voyage
VOYAGE_API_KEY=your-voyage-api-key-here

# Optional: print prompt and token usage to stdout
DEBUG=false
